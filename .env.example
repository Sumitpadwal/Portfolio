PORT=8000

# Optional local-development providers. Vercel does not require either key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Local embedding model downloaded and cached during npm run ingest.
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SCORE=0.24
